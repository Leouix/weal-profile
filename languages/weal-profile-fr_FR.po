#. Plugin Name of the plugin
#: weal-profile.php includes/class-weal-profile.php:202
#: includes/class-weal-profile.php:203
msgid "Weal Profile"
msgstr "Weal Profile"

#. Plugin URI of the plugin
#: weal-profile.php
msgid "https://weal.cloud"
msgstr "https://weal.cloud"

#. Description of the plugin
#: weal-profile.php
msgid ""
"Creates a personal account page where logged-in users can manage their "
"profile information and review their site activity."
msgstr ""
"Crée une page de compte personnel où les utilisateurs connectés peuvent "
"gérer leurs informations de profil et consulter leur activité sur le site."

#. Author of the plugin
#: weal-profile.php
msgid "leouix"
msgstr "leouix"

#. Author URI of the plugin
